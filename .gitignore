# macOS
.DS_Store

# osmosisd source/binary dir pulled down for the osmo-test-5 deployment;
# not part of the contracts repo
/osmosis/

# Runtime state generated by deploy_osmo_testnet.sh — per-deployment
# addresses, code IDs, pool addresses (not source of truth)
/osmo_testnet.state
/commit_pools.txt

# Shell scripts — deploy / test / verify helpers are kept out of the
# repo. They reference per-deployment state (osmo_testnet.state,
# commit_pools.txt) and call optimizer/docker tooling that not every
# checkout has installed. The previously-listed `/testing-knobs.sh`
# is now covered by this broader pattern.
*.sh

# Text file backups
**/*.rs.bk

# Build results
target/
artifacts/
./airdrop/artifacts/
artifacts/localsei.json
artifacts/sei-chain.json

# IDEs
.vscode/
.idea/
*.iml

# Dependencies
node_modules
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
ignite.log

# Auto-gen
.cargo-ok
.env
.env.local
.env.*.local
injective/
