# =====================================================================
# osmo-test-5 deploy/test config
# =====================================================================
# Sourced by deploy_osmo_testnet.sh and (later) pyth_vaa_pusher.sh +
# the test-scenario scripts. All values here are static config; runtime-
# discovered values (code IDs, contract addresses) get written to the
# state file at the bottom and read back by subsequent scripts.
# ---------------------------------------------------------------------

# ---- Chain ----
CHAIN_ID="osmo-test-5"
NODE="https://rpc.osmotest5.osmosis.zone:443"
GAS_PRICES="0.04uosmo"
GAS_ADJUSTMENT="1.3"
KEYRING="test"

# Test wallet name in the local keyring. The script reads its bech32
# address via `osmosisd keys show`, so this just has to match a
# pre-imported key. Faucet: https://faucet.testnet.osmosis.zone/
FROM="alice"

# ---- Denoms ----
# Native gas denom on osmo-test-5 — also doubles as the ATOM-side leg of
# the anchor pool (see Q3 in the design discussion: we use uosmo +
# Pyth's OSMO/USD feed so the on-chain anchor ratio matches the Pyth
# price the factory queries).
NATIVE_DENOM="uosmo"

# Tokenfactory subdenom. The full bluechip denom is
# `factory/<alice-addr>/${BLUECHIP_SUBDENOM}` and gets resolved at
# script run time once we have the address.
BLUECHIP_SUBDENOM="ubluechip"

# ---- Pyth ----
# Beta/Edge contract on osmo-test-5. Production data feed (same as
# Stable mainnet) — only the Wormhole guardian set differs. See:
#   https://docs.pyth.network/price-feeds/contract-addresses/cosmwasm
PYTH_CONTRACT="osmo1lltupx02sj99suakmuk4sr4ppqf34ajedaxut3ukjwkv6469erwqtpg9t3"

# Pythnet feed ID for OSMO/USD (Stable). The factory's
# `pyth_atom_usd_price_feed_id` is misleadingly named — it just means
# "USD price for the asset on the non-bluechip side of the anchor."
# Pointing it at OSMO/USD against a uosmo-side anchor pool gives
# mathematically consistent prices (anchor ratio × Pyth OSMO/USD =
# bluechip USD) so the 30% drift breaker doesn't fire on every update.
PYTH_OSMO_USD_FEED_ID="d9437c194a4b00ba9d7652cd9af3905e73ee15a2ca4152ac1f8d430cc322b857"

# Hermes endpoint for VAA pulls. The pyth_vaa_pusher script (later)
# polls `${HERMES_ENDPOINT}/api/latest_vaas?ids[]=...` and submits the
# returned VAAs to PYTH_CONTRACT.update_price_feeds.
HERMES_ENDPOINT="https://hermes-beta.pyth.network"

# Cadence the VAA pusher runs at. Must be < MAX_PRICE_AGE_SECONDS_BEFORE_STALE
# (90s) to keep Pyth state fresh; 30s leaves comfortable headroom and
# matches the keeper UpdateOraclePrice cooldown behaviour.
VAA_PUSH_INTERVAL_SECONDS="30"

# ---- Wasm artifacts ----
ARTIFACTS="artifacts"

# ---- State file ----
# Runtime values written by deploy_osmo_testnet.sh (code IDs, factory
# address, etc). Subsequent scripts source this in addition to the .env.
STATE_FILE="osmo_testnet.state"

# ---- Factory tunables ----
# Matched to the existing local-mock deploy script. Adjust for testnet
# scale if you want shorter commit thresholds (e.g. drop
# COMMIT_THRESHOLD_LIMIT_USD to a few hundred so a commit pool can be
# threshold-crossed quickly during testing).
COMMIT_THRESHOLD_LIMIT_USD="25000"
# Seconds between EmergencyWithdraw Phase 1 (initiate) and Phase 2 (drain).
# Pinned at factory instantiate; admin-tunable through ProposeConfigUpdate
# (48h timelock). Range: 60 .. 7d. Production default: 86_400 (24h).
EMERGENCY_WITHDRAW_DELAY_SECONDS="60"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
# Per-pool max bluechip lock (25,000 tokens at 6 decimals).
MAX_BLUECHIP_LOCK_PER_POOL="25000000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="7"
# Standard-pool creation fee in USD micro-units (6 decimals). $1 here.
# Confirmed nonzero in the design discussion (Q2): exercises the
# fee-forward + surplus-refund path in `execute_create_standard_pool`.
STANDARD_POOL_CREATION_FEE_USD="1000000"

# ---- Funding amounts ----
# Tokenfactory mint to the deployer's address. 10M ubluechip at 6
# decimals = 10,000,000 BLUECHIP — way over the per-pool lock cap, with
# headroom for funding the expand-economy contract, seeding the anchor
# pool, and running multiple commit pools.
BLUECHIP_INITIAL_MINT="10000000000000"

# Expand-economy seed funding (in tokenfactory bluechip micro-units).
# 10,000 BLUECHIP — enough to cover post-threshold mints across multiple
# test pools without re-funding mid-run.
EXPAND_ECONOMY_FUND="10000000000"

# Per-side anchor / oracle-eligible pool funding floor (audit M-4).
# The internal oracle's per-side liquidity gate is now USD-denominated
# (MIN_POOL_LIQUIDITY_USD = $5_000) with a 5_000 BC fallback per side
# (MIN_POOL_LIQUIDITY_FALLBACK_BLUECHIP_PER_SIDE) used during bootstrap
# and any oracle-unavailable window. Seed each oracle-eligible pool's
# bluechip side with at least this many micro-units to guarantee
# eligibility under both branches:
#
#   8_000 BC = 8_000_000_000 micro = 60% over the fallback floor and
#   well above $5k regardless of OSMO/USD spot.
#
# A pool below this threshold (per-side) will be skipped during oracle
# sampling — so anchor + every additional standard pool we want in
# the rotation set should each be seeded at this amount on the
# bluechip side.
ANCHOR_POOL_SEED_BLUECHIP_PER_SIDE="8000000000"

# Anchor uosmo seed (the non-bluechip leg). M-4's per-side floor only
# checks the bluechip side, so this can be smaller — it just sets the
# initial spot price. 200 OSMO at 6 decimals; bumps the deployer's
# total uosmo requirement to ~250 OSMO including gas.
ANCHOR_POOL_SEED_UOSMO="5000000"

# Funds attached to the factory.CreateStandardPool tx for the anchor.
# Sized 2x the STANDARD_POOL_CREATION_FEE_FALLBACK_BLUECHIP (100 BC)
# so the bootstrap-time fallback fee path is comfortably covered
# regardless of oracle availability; surplus is refunded on-chain.
STANDARD_POOL_FEE_FUNDS_BLUECHIP="50000000000"

# ---- Sanity-check minimum balance ----
# Minimum uosmo (gas) balance the deploy script requires before it
# starts. 50 OSMO covers wasm uploads (the expensive part), instantiate
# txs, anchor-pool creation, and a few commit-pool tests with comfort
# room. Faucet gives 10 OSMO per request — plan on hitting it ~5 times
# before the first run.
MIN_GAS_BALANCE="15000000"

# Higher minimum used by deploy_osmo_testnet_anchor.sh: factory.deploy
# only needs gas, but anchor-pool creation also seeds ANCHOR_POOL_SEED_UOSMO
# (200 OSMO) into the pool. Bumped to 250 OSMO so the anchor tx + a
# couple of swap tests fit comfortably.
MIN_GAS_BALANCE_ANCHOR="8000000"

# =====================================================================
# Reference: oracle-eligibility regime (audit M-3)
# =====================================================================
# As of the May 2026 oracle audit, two parallel inputs feed the oracle's
# eligible-pool snapshot:
#
#   (1) ORACLE_ELIGIBLE_POOLS — admin-curated allowlist (any pool kind).
#       Add: 48h timelock via ProposeAddOracleEligiblePool, then
#       ApplyAddOracleEligiblePool. Cancel before timelock with
#       CancelAddOracleEligiblePool. Remove (immediate) with
#       RemoveOracleEligiblePool.
#
#   (2) COMMIT_POOLS_AUTO_ELIGIBLE — global flag. When true, every
#       threshold-crossed PoolKind::Commit pool flows in automatically.
#       Defaults to FALSE on fresh instantiates. Flip via
#       ProposeSetCommitPoolsAutoEligible{enabled} (48h timelock) then
#       ApplySetCommitPoolsAutoEligible. Both ON→OFF and OFF→ON are
#       timelocked.
#
# Snapshot rebuild reads BOTH inputs, dedupes, runs the cross-contract
# liquidity / bluechip-side check (M-4 per-side floor), and writes
# ELIGIBLE_POOL_SNAPSHOT. Forced (permissionless, rate-limited ~12h):
# RefreshOraclePoolSnapshot.
#
# Implication for the testnet test plan:
# - At fresh deploy, neither input has anything in it — only the
#   anchor pool (handled separately by select_random_pools_with_atom)
#   feeds the oracle.
# - For rotation testing across multiple pools, slice 2 of the
#   rollout proposes BOTH a flag flip AND a few allowlist adds at
#   deploy time so the 48h timer starts running. Other tests
#   (bootstrap, TWAP, staleness) execute during that 48h window
#   against the anchor-only oracle. After the timelock elapses, the
#   apply calls land and RefreshOraclePoolSnapshot publishes the new
#   eligible set so rotation tests can run.
